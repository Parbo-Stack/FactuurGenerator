# FactuurFlow — Environment Variables
# Copy this file to .env and fill in the values.
# NEVER commit .env to version control!

# ── Database ───────────────────────────────────────────────────────────────────
# PostgreSQL connection string
# Format: postgresql://user:password@host:port/database
DATABASE_URL=postgresql://postgres:password@localhost:5432/factuurflow

# ── Session ────────────────────────────────────────────────────────────────────
# Random secret string for signing session cookies.
# Generate a secure value with: openssl rand -hex 32
SESSION_SECRET=replace-this-with-a-secure-random-string

# ── Email (Resend) ─────────────────────────────────────────────────────────────
# API key from Resend (https://resend.com)
# Required for sending invoices by email.
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Environment ────────────────────────────────────────────────────────────────
# "development" or "production"
NODE_ENV=development

# ── Port (optional) ────────────────────────────────────────────────────────────
# Port the Express server listens on. Defaults to 5000 if not set.
PORT=5000
