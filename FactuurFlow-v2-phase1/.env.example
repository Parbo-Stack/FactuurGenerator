# FactuurFlow — Omgevingsvariabelen
# Kopieer dit bestand naar .env en vul de waarden in.
# Commit .env NOOIT naar versiecontrole!

# ── Database ──────────────────────────────────────────────────────────────────
# PostgreSQL verbindingsstring
# Formaat: postgresql://gebruiker:wachtwoord@host:poort/database
DATABASE_URL=postgresql://postgres:wachtwoord@localhost:5432/factuurflow

# ── Sessie ────────────────────────────────────────────────────────────────────
# Willekeurige geheime string voor het ondertekenen van sessie-cookies.
# Genereer een veilige waarde met: openssl rand -hex 32
SESSION_SECRET=vervang-dit-met-een-veilige-willekeurige-string

# ── E-mail (Resend) ───────────────────────────────────────────────────────────
# API-sleutel van Resend (https://resend.com)
# Vereist voor het versturen van facturen per e-mail.
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Omgeving ──────────────────────────────────────────────────────────────────
# "development" of "production"
NODE_ENV=development
